<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xfunds.mapper.FxMarginTxnMapper">

    <resultMap id="BaseResultMap" type="com.xfunds.entity.FxMarginTxn">
        <id column="txn_id" property="txnId"/>
        <result column="margin_account_id" property="marginAccountId"/>
        <result column="trade_id" property="tradeId"/>
        <result column="txn_type" property="txnType"/>
        <result column="amount" property="amount"/>
        <result column="balance_after" property="balanceAfter"/>
        <result column="operator_id" property="operatorId"/>
        <result column="operate_time" property="operateTime"/>
        <result column="remark" property="remark"/>
    </resultMap>

    <select id="selectByMarginAccountId" resultMap="BaseResultMap">
        SELECT txn_id, margin_account_id, trade_id, txn_type, amount, balance_after,
               operator_id, operate_time, remark
        FROM fx_margin_txn
        WHERE margin_account_id = #{marginAccountId}
        ORDER BY operate_time DESC
    </select>

    <insert id="insert" parameterType="com.xfunds.entity.FxMarginTxn" useGeneratedKeys="true" keyProperty="txnId">
        INSERT INTO fx_margin_txn (margin_account_id, trade_id, txn_type, amount, balance_after,
            operator_id, operate_time, remark)
        VALUES (#{marginAccountId}, #{tradeId}, #{txnType}, #{amount}, #{balanceAfter},
            #{operatorId}, NOW(), #{remark})
    </insert>

</mapper>
