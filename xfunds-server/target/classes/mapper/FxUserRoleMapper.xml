<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.xfunds.mapper.FxUserRoleMapper">

    <select id="selectByUserId" resultType="com.xfunds.entity.FxUserRole">
        SELECT user_id, role_id
        FROM fx_user_role
        WHERE user_id = #{userId}
    </select>

    <insert id="insert" parameterType="com.xfunds.entity.FxUserRole">
        INSERT INTO fx_user_role (user_id, role_id)
        VALUES (#{userId}, #{roleId})
    </insert>

    <delete id="deleteByUserId">
        DELETE FROM fx_user_role
        WHERE user_id = #{userId}
    </delete>

    <select id="selectRoleCodesByUserId" resultType="java.lang.String">
        SELECT r.role_code
        FROM fx_user_role ur
        JOIN fx_role r ON ur.role_id = r.role_id
        WHERE ur.user_id = #{userId}
    </select>

</mapper>
